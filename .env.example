# ============================
# 应用配置
# ============================
APP_DEBUG=true
APP_ENV=development

# ============================
# 数据库配置
# ============================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# ============================
# Redis 配置（统一）
# ============================

# Redis 服务器地址
REDIS_HOST=127.0.0.1

# Redis 端口
REDIS_PORT=6379

# Redis 密码（如果没有密码，留空或删除此行）
REDIS_PASSWORD=

# Redis 数据库编号（0-15）
REDIS_DB=0

# ============================
# MongoDB 配置 (已禁用)
# ============================
# ❌ MongoDB 已禁用（仅用于实体机台日志，非核心功能）
# 如需启用，取消以下注释并在 config/database.php 中启用连接配置
#
# # MongoDB 服务器地址
# MONGODB_HOST=127.0.0.1
#
# # MongoDB 端口
# MONGODB_PORT=27017
#
# # MongoDB 数据库名
# MONGODB_DATABASE=luck3
#
# # MongoDB 用户名（如果不需要认证，留空）
# MONGODB_USERNAME=
#
# # MongoDB 密码（如果不需要认证，留空）
# MONGODB_PASSWORD=
#
# # MongoDB 认证数据库
# MONGODB_AUTH_DATABASE=admin

# ============================
# Cloudflare Turnstile 人机验证
# ============================

# 是否启用 Turnstile（true/false）
TURNSTILE_ENABLED=false

# Turnstile Site Key（公钥，前端使用）
TURNSTILE_SITE_KEY=

# Turnstile Secret Key（密钥，后端验证使用，保密）
TURNSTILE_SECRET_KEY=

# ============================
# 设备安全配置
# ============================

# 设备系统密钥（务必修改为64位随机字符串）
# 生成方法：php -r "echo bin2hex(random_bytes(32)) . PHP_EOL;"
DEVICE_SECRET_KEY=change_this_to_random_string_1234567890abcdef

# 验证服务器配置
DEVICE_AUTH_ENABLED=true
DEVICE_AUTH_HOST=10.0.0.100
DEVICE_AUTH_PORT=9501
DEVICE_AUTH_PROTOCOL=https

# 令牌配置
DEVICE_TOKEN_TTL=1800
DEVICE_TOKEN_ALGORITHM=HS256
DEVICE_TOKEN_REFRESH_THRESHOLD=600

# 安全配置
DEVICE_TIMESTAMP_TOLERANCE=300
DEVICE_ENABLE_REQUEST_SIGNATURE=false

# 限流配置
DEVICE_AUTH_MAX_ATTEMPTS=10
DEVICE_AUTH_FAIL_WINDOW=3600
DEVICE_AUTH_BAN_DURATION=86400

# 监控配置
DEVICE_ENABLE_ANOMALY_DETECTION=true
DEVICE_ENABLE_VERBOSE_LOGGING=false

# 告警配置
DEVICE_ALERT_CHANNELS=log
DEVICE_DINGTALK_WEBHOOK=
DEVICE_WECHAT_WEBHOOK=
DEVICE_ALERT_EMAIL=

# ============================
# WebSocket Push 推送服务配置
# ============================
# 说明：gk_work 连接到 gk_api 服务器的推送服务
# 注意：必须从 gk_api 服务器获取正确的配置信息

# WebSocket 服务地址（浏览器客户端连接）
# 格式：websocket://服务器IP或域名:端口
# 示例：websocket://47.98.123.45:3131 (公网IP)
#      websocket://api.yourdomain.com:3131 (域名)
#      websocket://192.168.1.100:3131 (内网IP，仅内网可访问)
PUSH_WEBSOCKET=websocket://127.0.0.1:3131

# API 服务地址（服务端推送使用，gk_work 发送推送到 gk_api）
# 格式：http://服务器IP:端口
# 建议：优先使用内网IP，速度更快更安全
# 示例：http://172.16.0.100:3232 (内网IP，推荐)
#      http://47.98.123.45:3232 (公网IP)
PUSH_API=http://127.0.0.1:3232

# 应用密钥（App Key）
# ⚠️ 重要：必须与 gk_api 服务器的配置完全一致
# 获取方法：在 gk_api 服务器执行
#   cat config/plugin/webman/push/app.php
# 复制其中的 app_key 值
PUSH_APP_KEY=your_app_key_from_gk_api

# 应用密钥（App Secret）
# ⚠️ 重要：必须与 gk_api 服务器的配置完全一致
# 获取方法：在 gk_api 服务器执行
#   cat config/plugin/webman/push/app.php
# 复制其中的 app_secret 值
PUSH_APP_SECRET=your_app_secret_from_gk_api

# ────────────────────────────
# 配置说明
# ────────────────────────────
# 1. 如果 gk_api 和 gk_work 在同一服务器：
#    PUSH_WEBSOCKET=websocket://127.0.0.1:3131
#    PUSH_API=http://127.0.0.1:3232
#
# 2. 如果 gk_api 和 gk_work 在不同服务器：
#    - PUSH_WEBSOCKET 使用 gk_api 的公网IP或域名（浏览器需要访问）
#    - PUSH_API 使用 gk_api 的内网IP（服务器间通信，可选公网IP）
#    - 确保 gk_api 服务器已开放 3131 和 3232 端口
#
# 3. 生产环境建议使用 WSS（WebSocket over SSL）：
#    PUSH_WEBSOCKET=wss://api.yourdomain.com/ws
#    需要配置 Nginx 反向代理和 SSL 证书
#
# ────────────────────────────
# 快速配置步骤
# ────────────────────────────
# 1. 在 gk_api 服务器查看推送配置：
#    cat config/plugin/webman/push/app.php
#
# 2. 记录以下信息：
#    - app_key
#    - app_secret
#    - gk_api 服务器的 IP 地址
#
# 3. 替换上面的配置值
#
# 4. 确保 gk_api 服务器：
#    - 推送服务监听 0.0.0.0（不是 127.0.0.1）
#    - 防火墙开放 3131 和 3232 端口
#    - 推送服务进程正在运行
#
# 详细文档：查看项目根目录的以下文件
# - 跨服务器推送配置指南.md
# - 快速配置推送.txt
# - 推送功能使用说明.md

# ============================
# Telegram 错误通知配置
# ============================
# 说明：当发生错误时，自动发送通知到 Telegram 机器人

# 是否启用 Telegram 通知（true/false）
TELEGRAM_ENABLED=false

# Telegram Bot Token（从 @BotFather 获取）
# 获取方法：
# 1. 打开 Telegram，搜索 @BotFather
# 2. 发送 /newbot 创建新机器人
# 3. 按提示设置机器人名称
# 4. 复制生成的 Token
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID（接收通知的聊天 ID）
# 获取方法：
# 1. 将机器人添加到你的频道/群组，或直接与机器人对话
# 2. 发送任意消息给机器人
# 3. 访问：https://api.telegram.org/bot你的TOKEN/getUpdates
# 4. 找到 "chat":{"id":数字} 复制这个数字
# 示例：-1001234567890 (群组) 或 123456789 (个人)
TELEGRAM_CHAT_ID=

# 应用名称（用于通知消息标题）
APP_NAME=GK-Work

# ────────────────────────────
# 配置说明
# ────────────────────────────
# 1. 创建 Telegram Bot：
#    - 搜索 @BotFather
#    - 发送 /newbot
#    - 获取 Bot Token
#
# 2. 获取 Chat ID：
#    - 方法一：个人聊天
#      · 与机器人发送消息
#      · 访问 https://api.telegram.org/bot你的TOKEN/getUpdates
#      · 找到 chat.id
#    
#    - 方法二：群组/频道
#      · 将机器人添加为管理员
#      · 在群组发送消息
#      · 访问上述链接找到 chat.id（通常是负数）
#
# 3. 配置本文件：
#    TELEGRAM_ENABLED=true
#    TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
#    TELEGRAM_CHAT_ID=-1001234567890
#
# 4. 重启服务生效
#
