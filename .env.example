# ============================
# 应用配置
# ============================
APP_DEBUG=true
APP_ENV=development

# ============================
# 数据库配置
# ============================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# ============================
# Redis 配置（统一）
# ============================

# Redis 服务器地址
REDIS_HOST=127.0.0.1

# Redis 端口
REDIS_PORT=6379

# Redis 密码（如果没有密码，留空或删除此行）
REDIS_PASSWORD=

# Redis 数据库编号（0-15）
REDIS_DB=0

# ============================
# MongoDB 配置
# ============================

# MongoDB 服务器地址
MONGODB_HOST=127.0.0.1

# MongoDB 端口
MONGODB_PORT=27017

# MongoDB 数据库名
MONGODB_DATABASE=luck3

# MongoDB 用户名（如果不需要认证，留空）
MONGODB_USERNAME=

# MongoDB 密码（如果不需要认证，留空）
MONGODB_PASSWORD=

# MongoDB 认证数据库
MONGODB_AUTH_DATABASE=admin

# ============================
# Cloudflare Turnstile 人机验证
# ============================

# 是否启用 Turnstile（true/false）
TURNSTILE_ENABLED=false

# Turnstile Site Key（公钥，前端使用）
TURNSTILE_SITE_KEY=

# Turnstile Secret Key（密钥，后端验证使用，保密）
TURNSTILE_SECRET_KEY=

# ============================
# 设备安全配置
# ============================

# 设备系统密钥（务必修改为64位随机字符串）
# 生成方法：php -r "echo bin2hex(random_bytes(32)) . PHP_EOL;"
DEVICE_SECRET_KEY=change_this_to_random_string_1234567890abcdef

# 验证服务器配置
DEVICE_AUTH_ENABLED=true
DEVICE_AUTH_HOST=10.0.0.100
DEVICE_AUTH_PORT=9501
DEVICE_AUTH_PROTOCOL=https

# 令牌配置
DEVICE_TOKEN_TTL=1800
DEVICE_TOKEN_ALGORITHM=HS256
DEVICE_TOKEN_REFRESH_THRESHOLD=600

# 安全配置
DEVICE_TIMESTAMP_TOLERANCE=300
DEVICE_ENABLE_REQUEST_SIGNATURE=false

# 限流配置
DEVICE_AUTH_MAX_ATTEMPTS=10
DEVICE_AUTH_FAIL_WINDOW=3600
DEVICE_AUTH_BAN_DURATION=86400

# 监控配置
DEVICE_ENABLE_ANOMALY_DETECTION=true
DEVICE_ENABLE_VERBOSE_LOGGING=false

# 告警配置
DEVICE_ALERT_CHANNELS=log
DEVICE_DINGTALK_WEBHOOK=
DEVICE_WECHAT_WEBHOOK=
DEVICE_ALERT_EMAIL=
